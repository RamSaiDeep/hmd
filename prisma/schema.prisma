generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// USER MODEL (controlled by auth → keep id manual)
//////////////////////////////////////////////////////

model User {
  id            String    @id
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  phone         String?
  room          String?
  role          String    @default("user") // user, member, admin
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  complaints    Complaint[]
  bookings      StudioBooking[]
}

//////////////////////////////////////////////////////
// NEXTAUTH MODELS (auto IDs)
//////////////////////////////////////////////////////

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

//////////////////////////////////////////////////////
// COMPLAINT SYSTEM
//////////////////////////////////////////////////////

model Complaint {
  id          String   @id @default(uuid())
  userId      String
  place       String
  issueType   String
  issueDetail String?
  description String?
  photoUrl    String?
  status      String   @default("Not Started") // Not Started, In Progress, Finished, Invalid Request
  priority    String   @default("Medium")      // Low, Medium, High
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

//////////////////////////////////////////////////////
// EVENT REQUEST SYSTEM
//////////////////////////////////////////////////////

model EventRequest {
  id              String   @id @default(uuid())
  eventName       String
  organizerName   String
  eventDate       String
  eventTime       String?
  departments     String[] // Dhwani, Prakash, Kriti
  dhwaniItems     Json?
  prakashVenue    String?
  prakashLighting String[]
  kritiNeeds      String?
  notes           String?
  status          String   @default("Pending")
  memberResponse  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

//////////////////////////////////////////////////////
// MUSIC REQUEST SYSTEM
//////////////////////////////////////////////////////

model MusicRequest {
  id         String   @id @default(uuid())
  eventName  String
  organizer  String
  eventDate  String
  eventTime  String?
  venue      String
  soundItems Json
  needsLight Boolean  @default(false)
  lighting   String[]
  notes      String?
  status     String   @default("Pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

//////////////////////////////////////////////////////
// STUDIO BOOKING SYSTEM
//////////////////////////////////////////////////////

model StudioBooking {
  id          String   @id @default(uuid())
  userId      String
  day         String
  slot        String
  purpose     String
  description String
  status      String   @default("Pending") // Pending, Confirmed, Cancelled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}